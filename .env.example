# PostgreSQL 配置
POSTGRES_DSN=postgres://fish:fish123456@localhost:5432/fish_website?sslmode=disable

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=fishminio
MINIO_SECRET_KEY=fishminio123456
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=fish-website

# 认证配置
