# ================================
# Docker Compose Production 基础变量
# ================================

# GHCR 仓库命名空间（通常是你的 GitHub 用户名或组织名）
GHCR_OWNER=your-github-username-or-org

# 发布镜像标签（建议使用 Git tag，如 v1.0.0；默认 latest）
IMAGE_TAG=latest

# 对外暴露端口
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ================================
# PostgreSQL 容器配置
# ================================
POSTGRES_USER=fish
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=fish_website

# 应用连接 PostgreSQL（容器内主机名为 postgres）
POSTGRES_DSN=postgres://fish:change-this-postgres-password@postgres:5432/fish_website?sslmode=disable

# ================================
# MinIO 容器配置
# ================================
MINIO_ROOT_USER=change-this-minio-user
MINIO_ROOT_PASSWORD=change-this-minio-password

# 应用连接 MinIO（容器内主机名为 minio）
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-this-minio-user
MINIO_SECRET_KEY=change-this-minio-password
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=fish-website

# ================================
# 应用运行配置
# ================================
ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=change-this-jwt-secret
SERVER_ADDRESS=:8080

# 日志配置
LOGGER_LEVEL=info
LOGGER_JSON=false
LOGGER_ADD_SOURCE=false
